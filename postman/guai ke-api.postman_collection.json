              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"parroquia_id\": 1,\n  \"categoria_id\": 1,\n  \"nombre_taller\": \"Taller de ejemplo\",\n  \"descripcion\": \"Taller de artesanía local.\",\n  \"longitud\": -66.12345,\n  \"latitud\": 10.12345,\n  \"direccion_detallada\": \"Calle Principal 123\",\n  \"telefono_whatsapp\": \"0414-1234567\",\n  \"imagen_principal\": \"https://example.com/imagen.jpg\",\n  \"galeria\": [\"https://example.com/1.jpg\", \"https://example.com/2.jpg\"],\n  \"accesibilidad_ids\": [1, 2]\n}"
