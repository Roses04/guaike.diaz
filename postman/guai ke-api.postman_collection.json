                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"es_verificado\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/operators/:id/verify",
              "host": ["{{baseUrl}}"],
              "path": ["api", "operators", ":id", "verify"]
            }
          }
        }
      ]
